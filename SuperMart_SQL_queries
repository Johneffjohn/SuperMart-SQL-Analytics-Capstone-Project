Question 5
-- a
SELECT o.order_id,
       c.first_name || ' ' || c.last_name AS customer_name,
       e.first_name || ' ' || e.last_name AS employee_name,
       o.order_date,
       o.status,
       o.shipping_city
FROM orders o
JOIN customers c ON o.customer_id = c.customer_id
JOIN employees e ON o.employee_id = e.employee_id
ORDER BY o.order_date DESC
LIMIT 50;

-- b
SELECT c.customer_id,
       c.first_name || ' ' || c.last_name AS full_name,
       c.city,
       COUNT(o.order_id) AS order_count
FROM customers c
LEFT JOIN orders o ON c.customer_id = o.customer_id
GROUP BY c.customer_id, full_name, c.city
ORDER BY order_count DESC, c.last_name;

-- c
SELECT o.order_id,
       o.order_date,
       c.first_name || ' ' || c.last_name AS customer_name,
       p.product_name,
       oi.quantity,
       oi.unit_price,
       oi.discount,
       oi.quantity * oi.unit_price * (1 - oi.discount) AS line_total
FROM order_items oi
JOIN orders o ON oi.order_id = o.order_id
JOIN customers c ON o.customer_id = c.customer_id
JOIN products p ON oi.product_id = p.product_id;

-- d
SELECT e.first_name || ' ' || e.last_name AS full_name,
       e.role,
       r.region_name,
       COUNT(o.order_id) AS total_orders
FROM employees e
LEFT JOIN orders o ON e.employee_id = o.employee_id
LEFT JOIN regions r ON e.region_id = r.region_id
GROUP BY full_name, e.role, r.region_name, e.last_name;

-- e
SELECT c.category_name,
       p.product_name,
       COUNT(DISTINCT oi.order_id) AS times_ordered,
       SUM(oi.quantity) AS total_qty
FROM products p
JOIN categories c ON p.category_id = c.category_id
LEFT JOIN order_items oi ON p.product_id = oi.product_id
GROUP BY c.category_name, p.product_name;

Question 6
-- a
SELECT product_name,
       c.category_name,
       unit_price,
       CASE 
           WHEN unit_price < 10000 THEN 'Budget'
           WHEN unit_price BETWEEN 10000 AND 99999 THEN 'Mid-Range'
           ELSE 'Premium'
       END AS price_tier
FROM products p
JOIN categories c ON p.category_id = c.category_id;

-- b
SELECT first_name || ' ' || last_name AS full_name,
       role,
       salary,
       CASE
           WHEN salary >= 100000 THEN 'Executive'
           WHEN salary BETWEEN 80000 AND 99999 THEN 'Senior'
           ELSE 'Entry Level'
       END AS pay_band
FROM employees;

-- c
SELECT o.order_id,
       o.order_date,
       o.status,
       SUM(oi.quantity * oi.unit_price * (1 - oi.discount)) AS total_value,
       CASE
           WHEN SUM(oi.quantity * oi.unit_price * (1 - oi.discount)) > 500000 THEN 'High Value'
           WHEN SUM(...) BETWEEN 100000 AND 500000 THEN 'Medium Value'
           ELSE 'Low Value'
       END AS value_category
FROM orders o
JOIN order_items oi ON o.order_id = oi.order_id
GROUP BY o.order_id, o.order_date, o.status;

-- d
SELECT c.category_name,
       COUNT(CASE WHEN p.unit_price < 10000 THEN 1 END) AS budget_count,
       COUNT(CASE WHEN p.unit_price BETWEEN 10000 AND 99999 THEN 1 END) AS mid_range_count,
       COUNT(CASE WHEN p.unit_price >= 100000 THEN 1 END) AS premium_count
FROM products p
JOIN categories c ON p.category_id = c.category_id
GROUP BY c.category_name;

