WITH customer_revenue AS (
    SELECT c.customer_id,
           c.first_name || ' ' || c.last_name AS full_name,
           c.city,
           SUM(oi.quantity * oi.unit_price * (1 - oi.discount)) AS total_revenue
    FROM customers c
